# Copy to .env and fill in. All Agent Core settings are read with the
# SCORPION_ prefix (see api/config.py); provider SDK keys (ANTHROPIC_API_KEY,
# OPENAI_API_KEY) are read directly by litellm without a prefix.

SCORPION_DATABASE_URL=postgresql+psycopg://es:es_dev_only@localhost:55432/es
SCORPION_HOST=127.0.0.1
SCORPION_PORT=8731
# `scorpion serve`/`launch` poll /healthz this many times (0.5s apart) before
# giving up on a fresh start (default 60 = 30s). Raise this if you see
# "Started but not responding yet" on a slow/cold machine even though the
# log shows a clean startup with no errors.
SCORPION_STARTUP_HEALTH_CHECK_RETRIES=60

# JSON array of litellm model strings, tried in order until one succeeds.
# Cloud example:  SCORPION_CODING_MODELS=["claude-sonnet-5","gpt-4o-mini"]
# Local example:  SCORPION_CODING_MODELS=["ollama/qwen2.5-coder"]
SCORPION_CODING_MODELS=[]
SCORPION_FAST_MODELS=[]

# Needed only if you put an ollama/... entry in the lists above.
SCORPION_OLLAMA_BASE_URL=http://localhost:11434
# Every LLM call is bounded by this hard wall-clock deadline in code,
# independent of whether the underlying provider honors its own timeout.
SCORPION_LLM_CALL_TIMEOUT_SECONDS=60

# Provider keys — set whichever provider(s) you're using. Never commit real values.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Coding Agent
SCORPION_SEMGREP_DOCKER_IMAGE=semgrep/semgrep:latest
SCORPION_SEMGREP_TIMEOUT_SECONDS=300
SCORPION_TEST_RUN_TIMEOUT_SECONDS=600
SCORPION_FIX_MAX_FINDINGS_PER_PATCH=5

# Pentest Agent / Tool Orchestrator
SCORPION_HTTPX_DOCKER_IMAGE=projectdiscovery/httpx:latest
SCORPION_NMAP_DOCKER_IMAGE=instrumentisto/nmap:latest
SCORPION_SUBFINDER_DOCKER_IMAGE=projectdiscovery/subfinder:latest
SCORPION_AMASS_DOCKER_IMAGE=caffix/amass
SCORPION_KATANA_DOCKER_IMAGE=projectdiscovery/katana:latest
SCORPION_NUCLEI_DOCKER_IMAGE=projectdiscovery/nuclei:latest
# No maintained official ffuf image exists — build one locally first:
#   docker build -t scorpion/ffuf:local docker/tools/ffuf
SCORPION_FFUF_DOCKER_IMAGE=scorpion/ffuf:local
SCORPION_FEROXBUSTER_DOCKER_IMAGE=epi052/feroxbuster
SCORPION_DALFOX_DOCKER_IMAGE=hahwul/dalfox:latest
SCORPION_SQLMAP_DOCKER_IMAGE=googlesky/sqlmap:latest
SCORPION_ZAP_DOCKER_IMAGE=zaproxy/zap-stable
# Published under GitHub Container Registry, not Docker Hub.
SCORPION_NIKTO_DOCKER_IMAGE=ghcr.io/sullo/nikto
SCORPION_TESTSSL_DOCKER_IMAGE=drwetter/testssl.sh
SCORPION_ARJUN_DOCKER_IMAGE=trickest/arjun
SCORPION_GAU_DOCKER_IMAGE=sxcurity/gau
# wayback deliberately excluded from the default — confirmed for real its
# CDX API can take 15+ minutes (and still not finish) against a domain with
# a large indexed history, unlike the other three which reliably finish in
# well under a minute.
SCORPION_GAU_PROVIDERS=otx,urlscan,commoncrawl
SCORPION_THEHARVESTER_DOCKER_IMAGE=secsi/theharvester
# Free, no-API-key sources only. Comma-separated, passed straight to
# theHarvester's -b.
SCORPION_THEHARVESTER_SOURCES=crtsh,hackertarget,otx,urlscan,rapiddns
SCORPION_WPSCAN_DOCKER_IMAGE=wpscanteam/wpscan
# Optional — free token (25 req/day) at https://wpscan.com/register, enables
# CVE cross-referencing for detected plugins/themes/core version. Without
# one, detection/enumeration still runs, just without known-vuln lookups.
SCORPION_WPSCAN_API_TOKEN=
SCORPION_TOOL_TIMEOUT_SECONDS=180
SCORPION_NUCLEI_TIMEOUT_SECONDS=300
# amass enum has its own internal -timeout (minutes), derived from this so
# it self-terminates and writes its output before this outer timeout would
# otherwise kill the container mid-run. Kept short since this runs on
# every scan now — raise for a slower/larger real target.
SCORPION_AMASS_TIMEOUT_SECONDS=60
SCORPION_FEROXBUSTER_TIMEOUT_SECONDS=180
# feroxbuster's own per-request timeout (-T), separate from the outer
# container timeout above — its 7s default means every request against a
# dead host waits the full 7s rather than failing fast.
SCORPION_FEROXBUSTER_REQUEST_TIMEOUT_SECONDS=4
# Nikto's -maxtime is derived from this, leaving a 30s buffer so it
# self-terminates and still writes a valid report before this outer
# timeout would otherwise kill the container mid-run.
SCORPION_NIKTO_TIMEOUT_SECONDS=600
# testssl.sh only ever runs against a confirmed https:// live URL (it
# doesn't fail fast against a plain-HTTP port, so this is skipped
# entirely rather than bounded for anything else) — this timeout is for
# the real TLS scan case.
SCORPION_TESTSSL_TIMEOUT_SECONDS=180
# Default enumeration (timthumbs/config-backups/db-exports/backup-folders/
# user-IDs) measured ~7s against a near-empty site; no-ops instantly against
# a non-WordPress target (see run_wpscan's scan_aborted handling).
SCORPION_WPSCAN_TIMEOUT_SECONDS=180
# Multi-source passive OSINT lookup (crt.sh, HackerTarget, OTX, urlscan,
# RapidDNS) — measured ~12-25s against a real domain with 5 sources.
SCORPION_THEHARVESTER_TIMEOUT_SECONDS=90
# Probes ~50 default candidate GET parameter names — measured ~1-2s against
# a trivial test target; budget more for a slow real site.
SCORPION_ARJUN_TIMEOUT_SECONDS=120
# otx alone measured ~2 minutes against a domain with an unusually large
# indexed history — budget generously since a real target could be
# similarly heavy.
SCORPION_GAU_TIMEOUT_SECONDS=180
SCORPION_ZAP_BASELINE_TIMEOUT_SECONDS=300
# zap-full-scan actively attacks every spidered page/param (not a fixed
# template set like nuclei) — measured ~2-6 min even against a trivial
# test site, budget generously for a real one.
SCORPION_ZAP_FULL_SCAN_TIMEOUT_SECONDS=900
SCORPION_ZAP_API_SCAN_TIMEOUT_SECONDS=300
SCORPION_SQLMAP_TIMEOUT_SECONDS=300
# confirm_impact mode (--dbs/--current-db/--banner, gated behind a
# SOW-granted "exploitation" tier — see docs on scorpion authorize-sow)
# needs blind extraction that can run far longer than plain detection.
SCORPION_SQLMAP_CONFIRM_IMPACT_TIMEOUT_SECONDS=900
# Metasploit RPC (msfrpcd) — a long-lived service started once via
# `scorpion launch` (docker/docker-compose.yml's msf_rpc), not a one-shot
# container. Must match MSF_RPC_USER/MSF_RPC_PASSWORD in docker/.env.
SCORPION_MSF_RPC_HOST=localhost
SCORPION_MSF_RPC_PORT=55553
SCORPION_MSF_RPC_USER=msf
SCORPION_MSF_RPC_PASSWORD=
SCORPION_MSF_MODULE_TIMEOUT_SECONDS=120
# Sandboxed browser (docker/docker-compose.yml's browser_sandbox) for
# `scan --adaptive` — a long-lived service like msf_rpc above, started
# once via `scorpion launch`. The Agent Core reaches it via localhost
# (the port docker-compose publishes to the host), same as
# SCORPION_MSF_RPC_HOST above — NOT container_host_alias, which is for
# the opposite direction (something inside a container reaching the host).
SCORPION_BROWSER_SANDBOX_HOST=localhost
SCORPION_BROWSER_CDP_PORT=9223
SCORPION_BROWSER_ACTION_TIMEOUT_SECONDS=30
# Hard cap on `scan --adaptive`'s planning loop so one run can't loop
# indefinitely racking up LLM calls/tool invocations.
SCORPION_ADAPTIVE_AGENT_MAX_STEPS=15
# Stops the adaptive loop early after this many consecutive steps with
# zero new findings — no point spending further LLM calls once nothing
# new is surfacing.
SCORPION_ADAPTIVE_AGENT_STALE_AFTER_STEPS=3
SCORPION_FFUF_WORDLIST_PATH=docker/tools/ffuf/wordlist.txt
# `scan` enumerates subdomains (subfinder), probes all of them + the root
# with httpx, then runs the rest of the pipeline against every host that
# responds — capped here so a target with hundreds of subdomains doesn't
# turn a several-minute scan into a several-hour one. Dropped hosts are
# still reported by subfinder, just not actively scanned.
SCORPION_MAX_ENUMERATED_HOSTS=5
SCORPION_SCOPE_VERIFICATION_TTL_DAYS=30
SCORPION_SELF_ATTEST_TTL_DAYS=1
# Docker Desktop (Windows/Mac) exposes the host at host.docker.internal
# automatically. Native Linux Docker doesn't — set this to the docker0
# bridge gateway IP instead (see docs/LINUX.md).
SCORPION_CONTAINER_HOST_ALIAS=host.docker.internal
